datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  PROJECT_MANAGER
  DATA_ENTRY_OPERATOR
}

enum ProjectStatus {
  PLANNING
  RUNNING
  COMPLETED
  ARCHIVED
}

enum ProjectType {
  CONSULTANCY
  SUPERVISION
  CONSTRUCTION
  SUPPLYING
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum SalaryStatus {
  PAID
  PARTIAL
  DUE
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  profileImage String?    @db.Text
  role         Role       @default(DATA_ENTRY_OPERATOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Project {
  id                     String            @id @default(uuid())
  name                   String
  code                   String            @unique
  clientName             String
  clientContactNumber    String
  projectLocation        String
  startDate              DateTime
  expectedCompletionDate DateTime
  estimatedBudget        String // Encrypted float
  status                 ProjectStatus     @default(PLANNING)
  projectType            ProjectType       @default(CONSTRUCTION)
  description            String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  materials        Material[]
  cashIns          CashIn[]
  cashOuts         CashOut[]
  labours          Labour[]
  documents        Document[]
  attendances      Attendance[]
  projectVendors   ProjectVendor[]
  projectSuppliers ProjectSupplier[]

  @@index([name])
  @@index([status])
}

model Supplier {
  id             String            @id @default(uuid())
  name           String
  companyName    String?
  phoneNumber    String
  email          String?
  address        String?
  openingBalance String            @default("0.0") // Encrypted float
  currentDue     String            @default("0.0") // Encrypted float
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  materials          Material[]
  cashOuts           CashOut[]
  documents          Document[]
  projectAssignments ProjectSupplier[]

  @@index([name])
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  companyName    String?
  contactNumber  String
  address        String?
  workType       String // e.g. Civil, Electrical, Plumbing
  contractAmount String          @default("0.0") // Encrypted float
  paidAmount     String          @default("0.0") // Encrypted float
  dueAmount      String          @default("0.0") // Encrypted float
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  cashOuts           CashOut[]
  documents          Document[]
  projectAssignments ProjectVendor[]

  @@index([name])
}

model Employee {
  id               String     @id @default(uuid())
  employeeId       String     @unique // custom ID like EMP-001
  fullName         String
  designation      String
  department       String
  phoneNumber      String
  email            String?
  joiningDate      DateTime
  monthlySalary    String // Encrypted float
  employmentStatus String     @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  salaries  Salary[]
  cashOuts  CashOut[]
  documents Document[]

  @@index([fullName])
}

model Labour {
  id               String       @id @default(uuid())
  name             String
  phoneNumber      String
  trade            String // e.g. Mason, Electrician, Helper
  dailyWage        String // Encrypted float
  employmentStatus String       @default("ACTIVE") // ACTIVE, INACTIVE
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  attendances Attendance[]
  cashOuts    CashOut[]
  documents   Document[]

  @@index([name])
  @@index([trade])
}

model Attendance {
  id        String           @id @default(uuid())
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  labourId  String
  labour    Labour           @relation(fields: [labourId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([labourId, date])
}

model Material {
  id            String   @id @default(uuid())
  name          String
  category      String // e.g. Cement, Steel, Sand, Bricks
  quantity      Float
  unit          String // e.g. Bags, Tons, CFT, Pcs
  unitPrice     String // Encrypted float
  totalPrice    String // Encrypted float
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  purchaseDate  DateTime
  invoiceNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cashOuts CashOut[]

  @@index([name])
  @@index([category])
}

model CashIn {
  id              String   @id @default(uuid())
  date            DateTime
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientName      String
  amount          String // Encrypted float
  paymentMethod   String // e.g. CASH, BANK, CHEQUE, MOBILE_BANKING
  bankOrCash      String // Name of account or "Cash in Hand"
  referenceNumber String?
  source          String // e.g. CLIENT_PAYMENT, ADVANCE_PAYMENT, INSTALLMENT, OTHER_INCOME
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientName])
  @@index([date])
}

model CashOut {
  id              String    @id @default(uuid())
  date            DateTime
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  expenseCategory String // e.g. MATERIALS, LABOR, EMPLOYEE_SALARY, CONTRACTOR_PAYMENT, OFFICE_RENT, UTILITIES, TRANSPORTATION, FUEL, EQUIPMENT_RENTAL, MISCELLANEOUS
  paidTo          String
  amount          String // Encrypted float
  paymentMethod   String // e.g. CASH, BANK, CHEQUE, MOBILE_BANKING
  referenceNumber String?
  notes           String?

  // Relations to track specific disbursements
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  labourId   String?
  labour     Labour?   @relation(fields: [labourId], references: [id], onDelete: SetNull)
  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  salaryId   String?
  salary     Salary?   @relation(fields: [salaryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paidTo])
  @@index([date])
}

model Salary {
  id            String       @id @default(uuid())
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month         String // Format: YYYY-MM
  basicSalary   String // Encrypted float
  bonus         String       @default("0.0") // Encrypted float
  deduction     String       @default("0.0") // Encrypted float
  netSalary     String // Encrypted float
  paidAmount    String       @default("0.0") // Encrypted float
  dueAmount     String       @default("0.0") // Encrypted float
  paymentStatus SalaryStatus @default(DUE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  cashOuts CashOut[]

  @@unique([employeeId, month])
}

model Document {
  id          String   @id @default(uuid())
  name        String
  url         String // URL or file path in supabase storage
  uploadDate  DateTime @default(now())
  description String?
  fileType    String // PDF, IMAGE, EXCEL, WORD, etc.
  category    String // CONTRACT, INVOICE, CHALLAN, QUOTATION, OTHER

  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  labourId   String?
  labour     Labour?   @relation(fields: [labourId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String // e.g. CREATE_PROJECT, UPDATE_EXPENSE
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  scope     String
  details   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model ProjectVendor {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  contractAmount String   @default("0.0") // Encrypted float
  paidAmount     String   @default("0.0") // Encrypted float
  dueAmount      String   @default("0.0") // Encrypted float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, vendorId])
}

model ProjectSupplier {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  contractAmount String   @default("0.0") // Encrypted float
  paidAmount     String   @default("0.0") // Encrypted float
  dueAmount      String   @default("0.0") // Encrypted float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, supplierId])
}
