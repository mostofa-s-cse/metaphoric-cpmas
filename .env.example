NODE_ENV=development

# PostgreSQL connection string (used by prisma.config.ts and src/lib/db.ts)
DATABASE_URL=postgresql://user:password@localhost:5432/cpmas?schema=public

# Auth
JWT_SECRET=

# Used to encrypt/decrypt financial amount fields (src/lib/crypto.ts)
ENCRYPTION_KEY=

# Fallback SMTP creds for the contact form (gmail), used if no SMTP_SETTINGS
# row exists in WebsiteSettings
SMTP_USER=
SMTP_PASS=

# Where contact form submissions get emailed
NOTIFICATION_EMAIL=
